            They witnessed you in your pursuit for the cure
            and was immpressed by your tenacity and willpower
            Their attempts to court you came off as
            death threats due to the clash in cultures
            They are here now to put their heart on the line and beg for a chance''')
    choose=input("What will you do?:")
    c=f"You decide to {choose} them."
    print(c)
    print("Happy Ending!")
    game_over()

def game_over():
    print("\n--- GAME OVER ---")
    play_again = input("Play again? (yes/no) ").lower()
    if play_again == "yes":
        intro()
    else:
        print("Thanks for playing!")


